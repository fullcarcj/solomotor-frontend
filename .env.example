# Paridad local / Render: copia este archivo a .env.local, rellena los valores
# (los mismos que en Environment del servicio frontend en Render) y reinicia `next dev`.
# Sin WEBHOOK_* y sin PRODUCT_IMAGE_* no hay lista ni miniaturas en ningún entorno.

VITE_API_URL=https://TU-BACKEND.onrender.com
VITE_FRONTEND_API_KEY=tu_frontend_api_key
VITE_IMG_BASE_URL=https://firebasestorage.googleapis.com/v0/b/webhook-receiver-b74d8.firebasestorage.app/o/productos%2F

# Imagen por SKU en Firebase (Next arma la URL; el Vite tienda-repuestos NO: el API Django devolvía fotos[].imagen ya completa).
# Define al menos una de: NEXT_PUBLIC_PRODUCT_IMAGE_BASE_URL | PRODUCT_IMAGE_BASE_URL | VITE_IMG_BASE_URL (misma URL; la última sirve si en Render solo tenías las vars del Vite antiguo).
# En Render: PRODUCT_IMAGE_BASE_URL o VITE_IMG_BASE_URL basta para /api/config/product-image-base si el build no inlined NEXT_PUBLIC_*.
# En este bucket las imágenes viven bajo la carpeta "productos/" (ver gs://.../productos/archivo.webp).
# Base con carpeta codificada: .../o/productos%2F  → el código infiere el prefijo "productos".
# Alternativa: base .../v0/b/<bucket>/o (sin %2F) + PRODUCT_IMAGE_STORAGE_PREFIX=productos
PRODUCT_IMAGE_BASE_URL=https://firebasestorage.googleapis.com/v0/b/webhook-receiver-b74d8.firebasestorage.app/o/productos%2F
# NEXT_PUBLIC_PRODUCT_IMAGE_BASE_URL=...

# Si la base termina en /o (sin carpeta), define el prefijo explícito (debe coincidir con la carpeta en Storage):
# PRODUCT_IMAGE_STORAGE_PREFIX=productos
# El valor que pases como SKU al componente debe coincidir con el nombre del archivo sin extensión
# (p.ej. 00001_FOO01_go_1 para 00001_FOO01_go_1.webp), no solo un código corto si el archivo tiene sufijo.

# Servidor Next (solo servidor): proxy a GET /api/inventory/products (requiere X-Admin-Secret en el backend)
# URL del backend (webhook-receiver) para BFF: menú dinámico GET /api/menu → `${BACKEND_URL}/api/menu`
# Si está vacío, se usa WEBHOOK_RECEIVER_BASE_URL.
BACKEND_URL=

# BFF bandeja: logs en terminal (URL, status, JSON). Por defecto apagado. Solo servidor: DEBUG_BFF=1
# DEBUG_BFF=

WEBHOOK_RECEIVER_BASE_URL=https://TU-SERVICIO-webhook.onrender.com
# Mismo string que ADMIN_SECRET del webhook-receiver. Si solo defines ADMIN_SECRET en Render, también sirve (el proxy la usa como respaldo).
WEBHOOK_ADMIN_SECRET=

# Listado/creación de cotizaciones (BFF → receiver). Por defecto `/api/inbox/quotations`. Si el GET global usa otra ruta, ej. `/api/quotations`:
# QUOTATIONS_UPSTREAM_PATH=/api/quotations

# Métodos de pago para /api/pos/payment-methods (BFF → receiver). Por defecto `/api/igtf/payment-methods`.
# POS_PAYMENT_METHODS_UPSTREAM_PATH=/api/igtf/payment-methods

# ID numérico del operador para bandeja omnicanal (sent_by / confirmed_by / created_by) hasta integrar auth real.
# NEXT_PUBLIC_INBOX_OPERATOR_ID=1
