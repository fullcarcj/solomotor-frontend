{
  "//": "TypeScript estricto SCOPED al módulo ventas + bandeja + sus APIs y tipos. Sprint 1.5 FE.",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/app/(features)/ventas/**/*.ts",
    "src/app/(features)/ventas/**/*.tsx",
    "src/app/(features)/bandeja/**/*.ts",
    "src/app/(features)/bandeja/**/*.tsx",
    "src/app/(features)/observacion/**/*.ts",
    "src/app/(features)/observacion/**/*.tsx",
    "src/app/(features)/workspace/**/*.ts",
    "src/app/(features)/workspace/**/*.tsx",
    "src/app/(features)/supervisor/**/*.ts",
    "src/app/(features)/supervisor/**/*.tsx",
    "src/app/api/ventas/**/*.ts",
    "src/app/api/bandeja/**/*.ts",
    "src/app/api/inbox/**/*.ts",
    "src/app/api/ai-responder/**/*.ts",
    "src/app/api/sales/**/*.ts",
    "src/constants/chatStage.ts",
    "src/types/inbox.ts",
    "src/types/supervisor.ts",
    "src/types/sales.ts",
    "src/types/customers.ts",
    "src/types/botActions.ts",
    "src/types/exceptions.ts",
    "src/hooks/useChatMessages.ts",
    "src/hooks/useChatContext.ts",
    "src/hooks/useInbox.ts",
    "src/hooks/useSales.ts",
    "src/hooks/useSupervisorKPIs.ts",
    "src/hooks/useSupervisorWaiting.ts",
    "src/hooks/useSupervisorExceptions.ts",
    "src/hooks/useAiResponderStats.ts",
    "src/hooks/useBotActions.ts",
    "src/hooks/useExceptions.ts",
    "src/hooks/useSupervisorBotActions.ts",
    "src/hooks/useExceptionsCount.ts",
    "src/hooks/useUnreviewedBotActionsCount.ts",
    "src/components/bandeja/ExceptionsPanel.tsx",
    "src/components/bandeja/BotActionsTimeline.tsx",
    "src/components/bandeja/ExceptionBadge.tsx",
    "src/components/bandeja/HandoffBadge.tsx",
    "src/components/supervisor/SupervisorExceptionsPanel.tsx",
    "src/components/supervisor/BotActionsReviewQueue.tsx",
    "src/lib/realtime/inboxStream.ts",
    "src/lib/bandejaReceiverProxy.ts"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
